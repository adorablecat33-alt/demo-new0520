<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TRS — 交易員下單</title>
<link rel="stylesheet" href="../css/main.css">
<style>
body { display:flex; height:100vh; overflow:hidden; }

/* ── LAYOUT ── */
.page-body {
  margin-left:56px;
  flex:1; display:flex; flex-direction:column; overflow:hidden;
}
.main-area {
  flex:1; display:grid;
  grid-template-columns: 260px 1fr 280px;
  overflow:hidden;
}
.panel {
  display:flex; flex-direction:column;
  border-right:1px solid var(--border);
  overflow:hidden;
}
.panel:last-child { border-right:none; }
.panel-header {
  padding:10px 14px;
  border-bottom:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between;
  flex-shrink:0;
  background:var(--bg-secondary);
}
.panel-title { font-size:11px; font-weight:600; color:var(--text-muted); letter-spacing:1px; text-transform:uppercase; }
.panel-body { flex:1; overflow-y:auto; padding:12px; display:flex; flex-direction:column; gap:10px; }

/* ── LEFT: 帳號/持倉 ── */
.acc-select-group { display:flex; flex-direction:column; gap:6px; }
.acc-select-group select { width:100%; }

.acc-summary {
  background:var(--bg-card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:10px 12px;
  display:flex; flex-direction:column; gap:6px;
}
.acc-row { display:flex; justify-content:space-between; align-items:center; }
.acc-label { font-size:11px; color:var(--text-muted); }
.acc-val   { font-family:var(--mono); font-size:12px; font-weight:600; }

.risk-section {
  background:var(--bg-card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:10px 12px;
}
.risk-title { font-size:11px; font-weight:600; color:var(--text-muted); letter-spacing:0.5px; margin-bottom:10px; }
.risk-item { margin-bottom:8px; }
.risk-item-header { display:flex; justify-content:space-between; margin-bottom:4px; }
.risk-item-label { font-size:10px; color:var(--text-muted); }
.risk-track { height:5px; background:var(--bg-tertiary); border-radius:3px; overflow:hidden; }
.risk-fill  { height:100%; border-radius:3px; transition:width 0.5s; }

.position-table { width:100%; border-collapse:collapse; }
.position-table th { font-size:10px; color:var(--text-muted); text-align:left; padding:4px 6px; border-bottom:1px solid var(--border); }
.position-table td { font-size:11px; padding:5px 6px; border-bottom:1px solid var(--border); color:var(--text-secondary); font-family:var(--mono); }
.position-table tr:hover td { background:var(--bg-hover); }

/* ── MIDDLE: K線 / 委託 / 成交 ── */
.tab-bar {
  display:flex; gap:0;
  border-bottom:1px solid var(--border);
  flex-shrink:0;
  background:var(--bg-secondary);
}
.tab {
  padding:8px 16px;
  font-size:12px; color:var(--text-muted);
  cursor:pointer; border-bottom:2px solid transparent;
  transition:all 0.15s;
  white-space:nowrap;
}
.tab:hover { color:var(--text-primary); }
.tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.tab-content { flex:1; overflow:hidden; }
.tab-pane { display:none; height:100%; overflow-y:auto; padding:12px; }
.tab-pane.active { display:flex; flex-direction:column; gap:8px; }

canvas#kline { width:100%; }
.kline-wrap { background:var(--bg-card); border-radius:var(--radius); overflow:hidden; flex:1; min-height:200px; position:relative; }

.order-row-header { display:grid; grid-template-columns:80px 48px 40px 70px 60px 1fr; gap:4px; padding:4px 6px; font-size:10px; color:var(--text-muted); border-bottom:1px solid var(--border); }
.order-row { display:grid; grid-template-columns:80px 48px 40px 70px 60px 1fr; gap:4px; padding:5px 6px; font-size:11px; border-bottom:1px solid var(--border); font-family:var(--mono); cursor:pointer; transition:background 0.1s; }
.order-row:hover { background:var(--bg-hover); }

/* ── RIGHT: 下單欄 ── */
.order-panel { background:var(--bg-secondary); }

.symbol-search {
  display:flex; gap:6px; align-items:center;
}
.symbol-input {
  flex:1; font-family:var(--mono); font-size:14px; font-weight:600;
  padding:7px 10px;
}
.price-display {
  background:var(--bg-card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:10px 12px;
}
.price-main  { font-family:var(--mono); font-size:22px; font-weight:700; }
.price-chg   { font-family:var(--mono); font-size:12px; margin-top:2px; }

.dir-btns { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
.dir-btn {
  padding:10px;
  border:1px solid;
  border-radius:var(--radius);
  font-size:14px; font-weight:700;
  cursor:pointer; transition:all 0.15s;
  letter-spacing:1px;
}
.dir-buy  { border-color:rgba(255,64,96,0.4);  background:rgba(255,64,96,0.08);  color:var(--up); }
.dir-sell { border-color:rgba(0,212,160,0.4);  background:rgba(0,212,160,0.08);  color:var(--down); }
.dir-buy.active  { background:var(--up);  border-color:var(--up);  color:#fff; }
.dir-sell.active { background:var(--down);border-color:var(--down);color:#000; }

.input-row { display:flex; align-items:center; gap:8px; }
.input-row label { font-size:11px; color:var(--text-muted); width:36px; flex-shrink:0; }
.input-row input, .input-row select { flex:1; }
.input-row .stepper { display:flex; }
.stepper-btn {
  width:28px; height:32px;
  background:var(--bg-card); border:1px solid var(--border-light);
  color:var(--text-primary); cursor:pointer; font-size:16px;
  display:flex; align-items:center; justify-content:center;
  transition:background 0.1s;
}
.stepper-btn:hover { background:var(--bg-hover); }
.stepper-btn.left  { border-radius:var(--radius) 0 0 var(--radius); border-right:none; }
.stepper-btn.right { border-radius:0 var(--radius) var(--radius) 0; border-left:none; }
.stepper-input {
  width:60px; border-radius:0; border-left:none; border-right:none;
  text-align:center; font-family:var(--mono); font-weight:600;
}

.seg-group { display:flex; gap:4px; flex-wrap:wrap; }
.seg-btn {
  padding:4px 10px;
  background:var(--bg-card); border:1px solid var(--border);
  border-radius:4px; color:var(--text-muted);
  font-size:11px; cursor:pointer; transition:all 0.15s;
}
.seg-btn:hover { border-color:var(--border-light); color:var(--text-primary); }
.seg-btn.active { background:var(--accent-glow); border-color:var(--accent); color:var(--accent); }

.risk-checklist {
  background:var(--bg-card); border:1px solid var(--border);
  border-radius:var(--radius); padding:8px 10px;
  display:flex; flex-direction:column; gap:4px;
}
.risk-check-item { display:flex; align-items:center; gap:6px; font-size:11px; }
.chk-pass   { color:var(--down); font-size:13px; }
.chk-warn   { color:var(--warn); font-size:13px; }
.chk-fail   { color:var(--danger); font-size:13px; }
.chk-pass-t { color:var(--text-secondary); }
.chk-warn-t { color:var(--warn); }
.chk-fail-t { color:var(--danger); }

.submit-area { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.submit-btn {
  padding:12px;
  border:none; border-radius:var(--radius);
  font-size:14px; font-weight:700; cursor:pointer;
  transition:all 0.15s; letter-spacing:1px;
}
.submit-buy  { background:var(--up);   color:#fff; }
.submit-sell { background:var(--down); color:#000; }
.submit-btn:hover { filter:brightness(1.1); }
.submit-btn:active { transform:scale(0.97); }

.est-row {
  display:flex; justify-content:space-between;
  font-size:11px; color:var(--text-muted);
  padding:2px 0;
}
.est-row .est-val { font-family:var(--mono); color:var(--text-secondary); }

/* lightning mode */
.lightning-btn {
  display:flex; align-items:center; gap:6px;
  padding:5px 10px;
  background:var(--bg-card); border:1px solid var(--border);
  border-radius:var(--radius);
  color:var(--text-muted); font-size:11px; cursor:pointer;
  transition:all 0.15s;
}
.lightning-btn.on { background:rgba(255,170,0,0.12); border-color:rgba(255,170,0,0.4); color:var(--warn); }
</style>
</head>
<body>

<!-- SIDEBAR NAV -->
<nav class="nav-sidebar">
  <a class="nav-logo" href="../index.html">⚡</a>
  <a class="nav-item active" data-page="trader" href="trader.html">
    <span>📊</span><span class="nav-tooltip">交易員下單</span>
  </a>
  <a class="nav-item" data-page="admin" href="admin.html">
    <span>🛡</span><span class="nav-tooltip">系統後台</span>
  </a>
  <a class="nav-item" data-page="risk" href="risk-alert.html">
    <span>🚨</span><span class="nav-tooltip">風險警報</span>
  </a>
  <div class="nav-divider"></div>
  <a class="nav-item nav-bottom" href="../index.html">
    <span>🚪</span><span class="nav-tooltip">登出</span>
  </a>
</nav>

<div class="page-body">
  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-title">交易員下單介面</div>
    <div style="display:flex;align-items:center;gap:8px;margin-left:12px;">
      <span class="badge badge-warn" id="traderTypeBadge">丙種</span>
      <span style="font-size:13px;font-weight:600;" id="traderName">交易員A</span>
    </div>
    <div class="topbar-right">
      <button class="lightning-btn" id="lightningBtn" onclick="toggleLightning()">
        <span>⚡</span><span>閃電模式</span>
      </button>
      <a class="btn btn-ghost btn-sm" href="../index.html">登出</a>
    </div>
  </div>

  <!-- INDEX BAR -->
  <div class="index-bar" id="indexBar"></div>

  <!-- MAIN -->
  <div class="main-area">

    <!-- LEFT: 帳號/持倉 -->
    <div class="panel">
      <div class="panel-header">
        <span class="panel-title">帳號 / 持倉</span>
        <span class="pulse-dot"></span>
      </div>
      <div class="panel-body">
        <div class="acc-select-group">
          <select id="traderSelect" onchange="changeTrader()">
            <option value="wzy">交易員A (丙種)</option>
            <option value="czl">交易員B (丙種)</option>
            <option value="chen">交易員C (自有)</option>
          </select>
          <select id="accountSelect" onchange="changeAccount()">
            <option value="sinopac_fut">永豐 期-台北3240627</option>
            <option value="sinopac_stk">永豐 證-敦南0388939</option>
            <option value="fubon_fut">富邦 期-0239847</option>
            <option value="kgi_stk">凱基 證-7832910</option>
          </select>
        </div>

        <div class="acc-summary">
          <div class="acc-row"><span class="acc-label">前日餘額</span><span class="acc-val mono">61,725,290</span></div>
          <div class="acc-row"><span class="acc-label">今日損益</span><span class="acc-val up" id="todayPnl">-4,450,000</span></div>
          <div class="acc-row"><span class="acc-label">未沖銷浮損</span><span class="acc-val up" id="floatPnl">-3,588,220</span></div>
          <div class="acc-row"><span class="acc-label">可動用保證金</span><span class="acc-val" id="avail">29,873,072</span></div>
          <div class="acc-row"><span class="acc-label">風險指標</span><span class="acc-val down" id="riskIdx">225%</span></div>
          <div class="acc-row"><span class="acc-label">帳號狀態</span><span class="badge badge-down" style="font-size:10px">正常</span></div>
        </div>

        <div class="risk-section">
          <div class="risk-title">風控使用率</div>
          <div class="risk-item">
            <div class="risk-item-header">
              <span class="risk-item-label">日損使用率</span>
              <span class="mono warn" style="font-size:10px" id="lossRateTxt">44.5%</span>
            </div>
            <div class="risk-track">
              <div class="risk-fill" id="lossRateBar" style="width:44.5%;background:var(--warn)"></div>
            </div>
          </div>
          <div class="risk-item">
            <div class="risk-item-header">
              <span class="risk-item-label">額度使用率</span>
              <span class="mono" style="font-size:10px;color:var(--accent)" id="quotaRateTxt">51.3%</span>
            </div>
            <div class="risk-track">
              <div class="risk-fill" id="quotaRateBar" style="width:51.3%;background:var(--accent)"></div>
            </div>
          </div>
        </div>

        <!-- 持倉表 -->
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:0.5px;text-transform:uppercase;">持倉明細</div>
        <table class="position-table">
          <thead>
            <tr><th>商品</th><th>口數</th><th>均價</th><th>浮損</th></tr>
          </thead>
          <tbody>
            <tr>
              <td><span style="color:var(--text-primary);font-size:11px">台半期066</span></td>
              <td class="up">買15</td>
              <td>82.40</td>
              <td class="up">-86,400</td>
            </tr>
            <tr>
              <td><span style="color:var(--text-primary);font-size:11px">台指期066</span></td>
              <td class="up">買3</td>
              <td>40,350</td>
              <td class="up">-1,230,000</td>
            </tr>
            <tr>
              <td><span style="color:var(--text-primary);font-size:11px">小台066</span></td>
              <td class="down">賣10</td>
              <td>40,280</td>
              <td class="down">+120,000</td>
            </tr>
            <tr>
              <td><span style="color:var(--text-primary);font-size:11px">華通期066</span></td>
              <td class="up">買43</td>
              <td>247.80</td>
              <td class="up">-2,392,000</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- MIDDLE: K線/委託/成交 -->
    <div class="panel">
      <div class="tab-bar">
        <div class="tab active" onclick="switchTab('kline',this)">K 線圖</div>
        <div class="tab" onclick="switchTab('orders',this)">委託記錄</div>
        <div class="tab" onclick="switchTab('trades',this)">成交回報</div>
        <div class="tab" onclick="switchTab('audit',this)">稽核日誌</div>
      </div>
      <div class="tab-content">

        <!-- K線 -->
        <div class="tab-pane active" id="pane-kline">
          <div style="display:flex;gap:8px;align-items:center;flex-shrink:0;">
            <span style="font-size:15px;font-weight:700;font-family:var(--mono);color:var(--text-primary);" id="chartSymbol">台半期066</span>
            <span class="badge badge-up" style="font-size:13px;" id="chartPrice">82.10</span>
            <span class="up mono" style="font-size:12px;" id="chartChg">▼ 0.30 (-0.36%)</span>
            <div style="margin-left:auto;display:flex;gap:4px;">
              <button class="seg-btn active" onclick="setTF('1m',this)">1分</button>
              <button class="seg-btn" onclick="setTF('5m',this)">5分</button>
              <button class="seg-btn" onclick="setTF('15m',this)">15分</button>
              <button class="seg-btn" onclick="setTF('D',this)">日</button>
            </div>
          </div>
          <div class="kline-wrap">
            <canvas id="kline"></canvas>
          </div>
          <!-- 五檔報價 -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:8px 10px;">
              <div style="font-size:10px;color:var(--text-muted);margin-bottom:6px;">賣方報價</div>
              <div id="askBook"></div>
            </div>
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:8px 10px;">
              <div style="font-size:10px;color:var(--text-muted);margin-bottom:6px;">買方報價</div>
              <div id="bidBook"></div>
            </div>
          </div>
        </div>

        <!-- 委託 -->
        <div class="tab-pane" id="pane-orders">
          <div style="display:flex;justify-content:space-between;align-items:center;flex-shrink:0;">
            <div style="font-size:11px;color:var(--text-muted);">今日委託記錄（模擬）</div>
            <span class="badge badge-accent">共 8 筆</span>
          </div>
          <div style="overflow-x:auto;">
            <div class="order-row-header">
              <span>時間</span><span>商品</span><span>方向</span><span>口數/價格</span><span>狀態</span><span>委託編號</span>
            </div>
            <div id="orderBook"></div>
          </div>
        </div>

        <!-- 成交 -->
        <div class="tab-pane" id="pane-trades">
          <div style="font-size:11px;color:var(--text-muted);">今日成交回報（模擬）</div>
          <table class="data-table">
            <thead>
              <tr><th>時間</th><th>商品</th><th>方向</th><th>口數</th><th>成交價</th><th>金額</th><th>手續費</th></tr>
            </thead>
            <tbody id="tradeBook"></tbody>
          </table>
        </div>

        <!-- 稽核 -->
        <div class="tab-pane" id="pane-audit">
          <div style="background:var(--warn-bg);border:1px solid rgba(255,170,0,0.2);border-radius:var(--radius);padding:8px 12px;font-size:11px;color:var(--warn);">
            ⚠ Append-Only · 所有記錄不可修改、不可刪除 · 稽核人員僅有唯讀權限
          </div>
          <table class="data-table">
            <thead>
              <tr><th>#</th><th>時間戳</th><th>操作人</th><th>動作</th><th>說明</th><th>設備指紋</th></tr>
            </thead>
            <tbody id="auditBook"></tbody>
          </table>
        </div>

      </div>
    </div>

    <!-- RIGHT: 下單 -->
    <div class="panel order-panel">
      <div class="panel-header">
        <span class="panel-title">下單</span>
        <span id="modeLabel" class="badge badge-muted" style="font-size:10px;">一般模式</span>
      </div>
      <div class="panel-body">

        <!-- 商品搜尋 -->
        <div class="symbol-search">
          <input class="form-input symbol-input" id="symbolInput" value="台半期066" placeholder="商品代號">
          <button class="btn btn-ghost btn-sm" onclick="searchSymbol()">查詢</button>
        </div>

        <!-- 即時報價 -->
        <div class="price-display">
          <div style="display:flex;align-items:baseline;gap:10px;">
            <div class="price-main up" id="livePriceMain">82.10</div>
            <div class="price-chg up" id="livePriceChg">▼ 0.30 (-0.36%)</div>
          </div>
          <div style="display:flex;gap:12px;margin-top:6px;">
            <span style="font-size:11px;color:var(--text-muted)">買<span class="mono down" id="liveAsk" style="margin-left:4px">82.10</span></span>
            <span style="font-size:11px;color:var(--text-muted)">賣<span class="mono up" id="liveBid" style="margin-left:4px">82.20</span></span>
            <span style="font-size:11px;color:var(--text-muted)">量<span class="mono" id="liveVol" style="margin-left:4px">1,243</span></span>
          </div>
        </div>

        <!-- 商品類型 -->
        <div>
          <div style="font-size:10px;color:var(--text-muted);margin-bottom:4px;">商品類型</div>
          <div class="seg-group" id="productTypeGroup">
            <button class="seg-btn active" onclick="setSeg('productTypeGroup',this)">現貨</button>
            <button class="seg-btn" onclick="setSeg('productTypeGroup',this)">融資</button>
            <button class="seg-btn" onclick="setSeg('productTypeGroup',this)">融券</button>
            <button class="seg-btn" onclick="setSeg('productTypeGroup',this)">當沖</button>
            <button class="seg-btn" onclick="setSeg('productTypeGroup',this)">期貨</button>
          </div>
        </div>

        <!-- 委託類型 -->
        <div>
          <div style="font-size:10px;color:var(--text-muted);margin-bottom:4px;">委託類型</div>
          <div class="seg-group" id="orderTypeGroup">
            <button class="seg-btn active" onclick="setSeg('orderTypeGroup',this)">限價</button>
            <button class="seg-btn" onclick="setSeg('orderTypeGroup',this)">市價</button>
            <button class="seg-btn" onclick="setSeg('orderTypeGroup',this)">ROD</button>
            <button class="seg-btn" onclick="setSeg('orderTypeGroup',this)">IOC</button>
            <button class="seg-btn" onclick="setSeg('orderTypeGroup',this)">FOK</button>
          </div>
        </div>

        <!-- 方向 -->
        <div class="dir-btns">
          <button class="dir-btn dir-buy active" id="dirBuy" onclick="setDir('buy')">買進</button>
          <button class="dir-btn dir-sell" id="dirSell" onclick="setDir('sell')">賣出</button>
        </div>

        <!-- 價格 -->
        <div class="input-row">
          <label>價格</label>
          <div style="flex:1;display:flex;gap:4px;">
            <div class="stepper">
              <button class="stepper-btn left" onclick="stepPrice(-1)">−</button>
              <input class="form-input stepper-input" type="number" id="priceInput" value="82.10" step="0.01" oninput="calcEst()">
              <button class="stepper-btn right" onclick="stepPrice(1)">+</button>
            </div>
          </div>
        </div>

        <!-- 數量 -->
        <div class="input-row">
          <label>口/張</label>
          <div style="flex:1;display:flex;gap:4px;">
            <div class="stepper">
              <button class="stepper-btn left" onclick="stepQty(-1)">−</button>
              <input class="form-input stepper-input" type="number" id="qtyInput" value="10" min="1" oninput="calcEst()">
              <button class="stepper-btn right" onclick="stepQty(1)">+</button>
            </div>
            <div class="seg-group" style="flex-wrap:nowrap;">
              <button class="seg-btn" onclick="setQty(1)">1</button>
              <button class="seg-btn" onclick="setQty(5)">5</button>
              <button class="seg-btn" onclick="setQty(10)">10</button>
              <button class="seg-btn" onclick="setQty(50)">50</button>
            </div>
          </div>
        </div>

        <!-- 預估金額 -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:8px 10px;">
          <div class="est-row"><span>預估委託金額</span><span class="est-val" id="estAmount">821,000</span></div>
          <div class="est-row"><span>手續費 (估)</span><span class="est-val" id="estFee">~205</span></div>
          <div class="est-row"><span>剩餘額度</span><span class="est-val down" id="estRemain">29,052,072</span></div>
        </div>

        <!-- 風控檢查 -->
        <div class="risk-checklist" id="riskChecklist">
          <div style="font-size:10px;font-weight:600;color:var(--text-muted);margin-bottom:4px;">Pre-Trade 風控檢查</div>
          <div class="risk-check-item"><span class="chk-pass">✓</span><span class="chk-pass-t">交易員啟用中</span></div>
          <div class="risk-check-item"><span class="chk-pass">✓</span><span class="chk-pass-t">帳號正常</span></div>
          <div class="risk-check-item"><span class="chk-pass">✓</span><span class="chk-pass-t">商品交易許可</span></div>
          <div class="risk-check-item"><span class="chk-pass">✓</span><span class="chk-pass-t">單筆口數未超限 (200口)</span></div>
          <div class="risk-check-item"><span class="chk-warn">!</span><span class="chk-warn-t">日損達 44.5%（警戒值 40%）</span></div>
          <div class="risk-check-item"><span class="chk-pass">✓</span><span class="chk-pass-t">額度充足</span></div>
          <div class="risk-check-item"><span class="chk-pass">✓</span><span class="chk-pass-t">帳號未鎖定</span></div>
          <div class="risk-check-item"><span class="chk-pass">✓</span><span class="chk-pass-t">未觸發熔斷</span></div>
        </div>

        <!-- 送單按鈕 -->
        <div class="submit-area">
          <button class="submit-btn submit-buy" onclick="submitOrder('buy')">買進送單</button>
          <button class="submit-btn submit-sell" onclick="submitOrder('sell')">賣出送單</button>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- CONFIRM MODAL -->
<div class="modal-overlay" id="confirmModal">
  <div class="modal-box">
    <div class="modal-header">
      <span style="font-size:20px;">⚠️</span>
      <div class="modal-header-title">確認送出委託</div>
    </div>
    <div class="modal-body">
      <div style="background:var(--warn-bg);border:1px solid rgba(255,170,0,0.2);border-radius:var(--radius);padding:8px 12px;font-size:12px;color:var(--warn);margin-bottom:12px;" id="modalWarnMsg">
        ⚡ 今日虧損達警戒值，需二次確認
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;" id="modalDetail"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('confirmModal')">取消</button>
      <button class="btn btn-primary" id="modalConfirmBtn" onclick="confirmOrder()">確認送出</button>
    </div>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>

<script src="../js/common.js"></script>
<script>
let currentDir = 'buy';
let lightningMode = false;
let orderSeq = 1000;
let pendingOrder = null;

const orders = [
  {ts:'14:47:08', sym:'台半期066', dir:'買進', qty:'10口', price:'82.10', status:'filled', id:'ORD-1001'},
  {ts:'14:46:55', sym:'台股指數056', dir:'賣出', qty:'2口', price:'40,283', status:'filled', id:'ORD-1000'},
  {ts:'14:42:10', sym:'小台066', dir:'賣出', qty:'10口', price:'市價', status:'filled', id:'ORD-0999'},
  {ts:'14:38:22', sym:'華通期066', dir:'買進', qty:'43口', price:'247.80', status:'filled', id:'ORD-0998'},
  {ts:'14:30:05', sym:'台半期066', dir:'買進', qty:'5口', price:'83.20', status:'cancelled', id:'ORD-0997'},
  {ts:'14:22:15', sym:'台指期066', dir:'買進', qty:'3口', price:'40,350', status:'filled', id:'ORD-0996'},
  {ts:'14:15:40', sym:'台半期066', dir:'賣出', qty:'20口', price:'83.50', status:'rejected', id:'ORD-0995'},
  {ts:'13:58:40', sym:'2330台積電', dir:'買進', qty:'50張', price:'980', status:'pending', id:'ORD-0994'},
];
const trades = [
  {ts:'14:47:08', sym:'台半期066', dir:'買進', qty:10, price:'82.10', amount:'821,000', fee:'205'},
  {ts:'14:46:55', sym:'台股指數056', dir:'賣出', qty:2, price:'40,283', amount:'8,056,600', fee:'2,014'},
  {ts:'14:42:10', sym:'小台066', dir:'賣出', qty:10, price:'40,248', amount:'10,062,000', fee:'2,515'},
  {ts:'14:38:22', sym:'華通期066', dir:'買進', qty:43, price:'247.80', amount:'10,655,400', fee:'2,663'},
];
const audits = [
  {seq:1001, ts:'14:47:08', user:'交易員A', action:'ORDER_SUBMIT', detail:'台半期066 買進 10口 82.10 → 永豐期台北', fp:'f3a9b2e1'},
  {seq:1000, ts:'14:46:55', user:'交易員A', action:'ORDER_SUBMIT', detail:'台股指數056 賣出 2口 40283 → 永豐期台北', fp:'f3a9b2e1'},
  {seq:999,  ts:'14:22:15', user:'系統',    action:'RISK_ALERT',  detail:'風險指標 121% 超標 → 交易員B 帳號', fp:'SYSTEM'},
  {seq:998,  ts:'14:10:00', user:'管理員',  action:'RULE_UPDATE', detail:'調整交易員A日損限額至 10,000,000', fp:'ad8c3f12'},
  {seq:997,  ts:'13:58:40', user:'交易員C', action:'ORDER_CONFIRM', detail:'大額委託二次確認 2330 買50張 @980', fp:'c7d1a4e9'},
];

// ── INIT ──
window.onload = () => {
  renderIndexBar();
  setInterval(tickMarket, 3000);
  setInterval(tickPrice, 2000);
  startClock(null);
  setInterval(() => {
    const el = document.getElementById('clockDisplay');
    if (el) el.textContent = fmtTime();
  }, 1000);
  renderOrderBook();
  renderTradeBook();
  renderAuditBook();
  renderOrderBook5();
  drawKLine();
};

// ── TAB ──
function switchTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('pane-' + tab).classList.add('active');
  if (tab === 'kline') setTimeout(drawKLine, 50);
}

// ── SEG ──
function setSeg(groupId, el) {
  document.querySelectorAll('#' + groupId + ' .seg-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  calcEst();
}

// ── DIR ──
function setDir(d) {
  currentDir = d;
  document.getElementById('dirBuy').classList.toggle('active', d === 'buy');
  document.getElementById('dirSell').classList.toggle('active', d === 'sell');
}

// ── LIGHTNING ──
function toggleLightning() {
  lightningMode = !lightningMode;
  const btn = document.getElementById('lightningBtn');
  const label = document.getElementById('modeLabel');
  btn.classList.toggle('on', lightningMode);
  label.textContent = lightningMode ? '⚡ 閃電模式' : '一般模式';
  label.className = 'badge ' + (lightningMode ? 'badge-warn' : 'badge-muted');
  label.style.fontSize = '10px';
  showToast(lightningMode ? '⚡ 閃電模式啟動' : '閃電模式關閉',
            lightningMode ? '風控仍強制執行' : '已切換回一般模式',
            lightningMode ? 'warn' : 'success');
}

// ── PRICE/QTY STEPPERS ──
function stepPrice(d) {
  const el = document.getElementById('priceInput');
  el.value = (parseFloat(el.value) + d * 0.01).toFixed(2);
  calcEst();
}
function stepQty(d) {
  const el = document.getElementById('qtyInput');
  el.value = Math.max(1, parseInt(el.value) + d);
  calcEst();
}
function setQty(n) {
  document.getElementById('qtyInput').value = n;
  calcEst();
}
function setTF(tf, el) {
  document.querySelectorAll('.seg-btn').forEach(b => { if(['1m','5m','15m','D'].some(t => b.textContent.includes(t.replace('m','分').replace('D','日')))) b.classList.remove('active'); });
  el.classList.add('active');
  drawKLine();
}

// ── CALC ──
function calcEst() {
  const price = parseFloat(document.getElementById('priceInput').value) || 0;
  const qty = parseInt(document.getElementById('qtyInput').value) || 0;
  const amount = price * qty * 1000;
  const fee = Math.round(amount * 0.00025);
  const remain = 29873072 - amount;
  document.getElementById('estAmount').textContent = fmt(amount);
  document.getElementById('estFee').textContent = '~' + fmt(fee);
  document.getElementById('estRemain').textContent = fmt(remain);
  document.getElementById('estRemain').className = 'est-val ' + (remain < 0 ? 'danger' : 'down');
}

// ── ORDER SUBMIT ──
function submitOrder(dir) {
  currentDir = dir;
  const qty = parseInt(document.getElementById('qtyInput').value) || 0;
  const price = document.getElementById('priceInput').value;
  const sym = document.getElementById('symbolInput').value;
  const amount = parseFloat(price) * qty * 1000;

  if (qty > 200) {
    showToast('❌ 風控拒絕', '單筆口數超過限制 200口', 'danger');
    return;
  }

  const warns = [];
  if (amount > 5000000) warns.push('大額委託');
  if (price === '市價' || price === '0') warns.push('市價單');
  warns.push('今日虧損達警戒值 44.5%');

  pendingOrder = { dir, qty, price, sym, amount };

  if (!lightningMode || warns.length > 0) {
    // show confirm modal
    document.getElementById('modalWarnMsg').textContent = '⚠ ' + warns.join('、') + ' — 需二次確認';
    const accLabel = document.getElementById('accountSelect').options[document.getElementById('accountSelect').selectedIndex]?.text || '—';
    document.getElementById('modalDetail').innerHTML = `
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:12px;">
        ${[
          ['使用帳號', accLabel],
          ['路由帳號', accLabel],
          ['商品', sym],
          ['方向', dir === 'buy' ? '<span class="up">買進</span>' : '<span class="down">賣出</span>'],
          ['口數', qty + '口'],
          ['價格', '限價 ' + price],
          ['預估金額', fmt(amount)],
          ['剩餘額度', fmt(29873072 - amount)],
          ['今日損益', '<span class="up">-4,450,000</span>'],
        ].map(([k,v]) => `<div style="color:var(--text-muted)">${k}</div><div style="font-family:var(--mono);text-align:right">${v}</div>`).join('')}
      </div>
    `;
    const btn = document.getElementById('modalConfirmBtn');
    btn.className = 'btn ' + (dir === 'buy' ? 'btn-danger' : 'btn-primary');
    btn.textContent = dir === 'buy' ? '確認買進' : '確認賣出';
    openModal('confirmModal');
  } else {
    executeOrder();
  }
}

function confirmOrder() {
  closeModal('confirmModal');
  executeOrder();
}

function executeOrder() {
  if (!pendingOrder) return;
  const { dir, qty, price, sym } = pendingOrder;
  orderSeq++;
  const now = fmtTime();
  orders.unshift({ ts:now, sym, dir: dir==='buy'?'買進':'賣出', qty:qty+'口', price, status:'filled', id:'ORD-'+orderSeq });
  renderOrderBook();
  audits.unshift({ seq:orderSeq, ts:now, user:'交易員A', action:'ORDER_SUBMIT', detail:`${sym} ${dir==='buy'?'買進':'賣出'} ${qty}口 ${price}`, fp:'f3a9b2e1' });
  renderAuditBook();
  showToast('✅ 委託送出', `${sym} ${dir==='buy'?'買進':'賣出'} ${qty}口 @${price}`, 'success');
  pendingOrder = null;
}

// ── RENDERS ──
function renderOrderBook() {
  const statusMap = {
    filled: '<span class="badge badge-down">成交</span>',
    pending: '<span class="badge badge-warn">委託中</span>',
    cancelled: '<span class="badge badge-muted">已撤</span>',
    rejected: '<span class="badge badge-danger">拒絕</span>',
  };
  document.getElementById('orderBook').innerHTML = orders.map(o => `
    <div class="order-row">
      <span class="mono">${o.ts}</span>
      <span style="color:var(--text-primary)">${o.sym}</span>
      <span class="${o.dir==='買進'?'up':'down'}">${o.dir}</span>
      <span class="mono">${o.qty} @${o.price}</span>
      <span>${statusMap[o.status]||''}</span>
      <span class="mono muted" style="font-size:10px">${o.id}</span>
    </div>
  `).join('');
}

function renderTradeBook() {
  document.getElementById('tradeBook').innerHTML = trades.map(t => `
    <tr>
      <td class="mono">${t.ts}</td>
      <td style="color:var(--text-primary)">${t.sym}</td>
      <td class="${t.dir==='買進'?'up':'down'}">${t.dir}</td>
      <td class="mono">${t.qty}</td>
      <td class="mono">${t.price}</td>
      <td class="mono">${t.amount}</td>
      <td class="mono muted">${t.fee}</td>
    </tr>
  `).join('');
}

function renderAuditBook() {
  document.getElementById('auditBook').innerHTML = audits.map(a => `
    <tr>
      <td class="mono muted">${a.seq}</td>
      <td class="mono">${a.ts}</td>
      <td>${a.user}</td>
      <td><span class="badge badge-accent" style="font-size:10px">${a.action}</span></td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;font-size:11px">${a.detail}</td>
      <td class="mono muted" style="font-size:10px">${a.fp}</td>
    </tr>
  `).join('');
}

function renderOrderBook5() {
  const base = 82.10;
  let askHtml = '', bidHtml = '';
  for (let i = 5; i >= 1; i--) {
    const p = (base + i * 0.1).toFixed(2);
    const v = Math.floor(Math.random() * 300 + 50);
    askHtml += `<div style="display:flex;justify-content:space-between;font-size:11px;padding:2px 0;">
      <span class="mono up">${p}</span><span class="mono muted">${v}</span></div>`;
  }
  for (let i = 0; i < 5; i++) {
    const p = (base - i * 0.1).toFixed(2);
    const v = Math.floor(Math.random() * 300 + 50);
    bidHtml += `<div style="display:flex;justify-content:space-between;font-size:11px;padding:2px 0;">
      <span class="mono down">${p}</span><span class="mono muted">${v}</span></div>`;
  }
  document.getElementById('askBook').innerHTML = askHtml;
  document.getElementById('bidBook').innerHTML = bidHtml;
}

// ── PRICE TICK ──
function tickPrice() {
  const p = parseFloat(document.getElementById('livePriceMain').textContent);
  const np = (p + (Math.random() - 0.5) * 0.3).toFixed(2);
  document.getElementById('livePriceMain').textContent = np;
  document.getElementById('chartPrice').textContent = np;
  document.getElementById('liveAsk').textContent = np;
  document.getElementById('liveBid').textContent = (parseFloat(np) + 0.1).toFixed(2);
  document.getElementById('liveVol').textContent = fmt(Math.floor(Math.random() * 2000 + 500));
  renderOrderBook5();
}

// ── K-LINE ──
function drawKLine() {
  const canvas = document.getElementById('kline');
  const wrap = canvas.parentElement;
  canvas.width = wrap.clientWidth;
  canvas.height = wrap.clientHeight;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;

  ctx.fillStyle = '#090c10';
  ctx.fillRect(0, 0, W, H);

  // grid
  ctx.strokeStyle = '#1b2235'; ctx.lineWidth = 1;
  for (let i = 1; i < 8; i++) { const y = H/8*i; ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
  for (let i = 1; i < 14; i++) { const x = W/14*i; ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }

  const bars = 60;
  const bw = Math.max(3, Math.floor(W/bars) - 1);
  let p = 82, candles = [];
  for (let i = 0; i < bars; i++) {
    const o = p, c = Math.max(78, Math.min(88, o + (Math.random()-0.48)*0.8));
    const h = Math.max(o,c) + Math.random()*0.4, l = Math.min(o,c) - Math.random()*0.4;
    candles.push({o,c,h,l}); p = c;
  }
  const maxH = Math.max(...candles.map(c=>c.h));
  const minL = Math.min(...candles.map(c=>c.l));
  const range = maxH - minL;
  const toY = v => H*0.05 + H*0.75*(1-(v-minL)/range);

  candles.forEach((c, i) => {
    const x = Math.floor(W/bars*i) + 2;
    const bull = c.c >= c.o;
    const col = bull ? '#00d4a0' : '#ff4060';
    ctx.strokeStyle = col; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(x+bw/2, toY(c.h)); ctx.lineTo(x+bw/2, toY(c.l)); ctx.stroke();
    ctx.fillStyle = bull ? 'rgba(0,212,160,0.8)' : 'rgba(255,64,96,0.85)';
    const y1 = toY(Math.max(c.o,c.c)), y2 = toY(Math.min(c.o,c.c));
    ctx.fillRect(x, y1, bw, Math.max(1, y2-y1));
  });

  // moving avg line
  ctx.strokeStyle = 'rgba(61,126,255,0.6)'; ctx.lineWidth = 1.5;
  ctx.beginPath();
  candles.forEach((c, i) => {
    if (i < 5) return;
    const avg = candles.slice(i-5,i).reduce((s,b)=>s+b.c,0)/5;
    const x = Math.floor(W/bars*i)+2+bw/2;
    i === 5 ? ctx.moveTo(x, toY(avg)) : ctx.lineTo(x, toY(avg));
  });
  ctx.stroke();
}

function changeTrader() {
  const t = AppState.traders[document.getElementById('traderSelect').value];
  if (!t) return;
  document.getElementById('traderName').textContent = t.name;
  document.getElementById('traderTypeBadge').textContent = t.type === 'CAPITAL' ? '丙種' : '自有';
  document.getElementById('todayPnl').textContent = fmtPnl(t.todayPnl);
  document.getElementById('floatPnl').textContent = fmtPnl(t.floatPnl);
  document.getElementById('avail').textContent = fmt(t.avail);
  document.getElementById('riskIdx').textContent = t.risk + '%';
  document.getElementById('lossRateTxt').textContent = t.lossRate + '%';
  document.getElementById('lossRateBar').style.width = t.lossRate + '%';
  document.getElementById('lossRateBar').style.background = t.lossRate >= 80 ? 'var(--danger)' : t.lossRate >= 60 ? 'var(--warn)' : 'var(--accent)';
  document.getElementById('quotaRateTxt').textContent = t.quotaRate + '%';
  document.getElementById('quotaRateBar').style.width = t.quotaRate + '%';
}
function changeAccount() {}
function searchSymbol() {
  showToast('商品查詢', document.getElementById('symbolInput').value + ' 已更新', 'info');
}
</script>
